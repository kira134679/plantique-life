<div class="container d-flex flex-column gap-8">
  <!-- head -->

  <div class="d-flex flex-column gap-1">
    <div class="d-flex justify-content-between align-items-center">
      <span class="fs-xs fs-lg-sm text-primary bg-primary-100 px-2 px-lg-3 py-1">質感精選</span>
      <button type="button" class="btn bg-transparent border-0 p-0">
        <span class="material-symbols-rounded text-neutral-700 p-2 p-lg-3 bg-white bg-opacity-40 rounded-circle">
          favorite
        </span>
      </button>
    </div>

    <div class="d-flex justify-content-between align-items-center">
      <h2 class="fs-5 text-neutral-700">荒原綠影</h2>
      <span class="fs-sm text-danger">剩餘 5 件</span>
    </div>

    <p class="noto-serif-tc fw-bold fs-5 lh-sm text-primary-700">NT$2,400</p>
  </div>

  <!-- payment -->

  <div>
    <div class="fs-sm text-neutral-400">
      <div class="d-flex justify-content-start">
        <span>付款方式</span>
        <ul class="d-flex flex-column gap-1">
          <li>全館滿 5,000 免運</li>
          <li>仙人掌系列買五送一</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- add-on -->

  <div>
    <span class="d-block fs-sm text-neutral-400 mb-3">加購商品</span>
    <ul class="list-unstyled d-flex flex-column gap-3">
      <li class="d-flex justify-content-between gap-3">
        <div class="add-on-display add-on-img-container">
          <img src="/assets/images/test.png" alt="img_product_add_01" class="object-fit-cover" />
        </div>
        <div class="add-on-display d-flex flex-column justify-content-around gap-3">
          <div class="d-flex flex-column gap-1">
            <h4 class="fs-7 text-neutral-700">噴霧器</h4>
            <p class="noto-serif-tc fw-bold lh-sm text-primary-700">NT$129<s class="fs-sm text-neutral-400">$249</s></p>
          </div>
          <div class="d-flex justify-content-between align-items-center gap-1">
            <button type="button" class="btn p-2 rounded-circle border border-2 flex-shrink-0 flex-grow-0">
              <span class="material-symbols-rounded align-bottom"> remove </span>
            </button>
            <span class="noto-serif-tc fw-bold lh-sm">0</span>
            <button type="button" class="btn p-2 rounded-circle border border-2">
              <span class="material-symbols-rounded align-bottom"> add_2 </span>
            </button>
          </div>
        </div>
      </li>
      <li class="d-flex justify-content-between gap-3">
        <div class="add-on-display add-on-img-container">
          <img src="/assets/images/img_product_add_02.png" alt="img_product_add_02" class="object-fit-cover" />
        </div>
        <div class="add-on-display d-flex flex-column justify-content-around gap-3">
          <div class="d-flex flex-column gap-1">
            <h4 class="fs-7 text-neutral-700">噴霧器</h4>
            <p class="noto-serif-tc fw-bold lh-sm text-primary-700">NT$129<s class="fs-sm text-neutral-400">$249</s></p>
          </div>
          <div class="d-flex justify-content-between align-items-center gap-1">
            <button type="button" class="btn p-2 rounded-circle border border-2 flex-shrink-0 flex-grow-0">
              <span class="material-symbols-rounded align-bottom"> remove </span>
            </button>
            <span class="noto-serif-tc fw-bold lh-sm">0</span>
            <button type="button" class="btn p-2 rounded-circle border border-2">
              <span class="material-symbols-rounded align-bottom"> add_2 </span>
            </button>
          </div>
        </div>
      </li>
    </ul>
  </div>

  <!-- add to cart -->

  <div>
    <div class="d-flex align-items-center gap-3 mb-4">
      <div class="w-50 d-flex justify-content-between align-items-center gap-1">
        <button type="button" class="btn p-3 rounded-circle border border-2 flex-shrink-0 flex-grow-0">
          <span class="material-symbols-rounded align-bottom"> remove </span>
        </button>
        <span class="noto-serif-tc fw-bold fs-6 lh-sm">1</span>
        <button type="button" class="btn p-3 rounded-circle border border-2">
          <span class="material-symbols-rounded align-bottom"> add_2 </span>
        </button>
      </div>
      <button type="button" class="w-50 btn border border-2 border-neutral-200 rounded-pill py-3 px-6">
        加入購物車
      </button>
    </div>

    <button type="button" class="btn text-white bg-primary rounded-pill py-3 px-6 w-100">立即購買</button>
  </div>
</div>
